{
  "name": "@adminforth/agent",
  "version": "1.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "homepage": "https://adminforth.dev/docs/tutorial/Plugins/agent/",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && rsync -av --exclude 'node_modules' custom dist/"
  },
  "keywords": [
    "adminforth",
    "ai-agent",
    "tool-calling",
    "chat-ui",
    "langgraph",
    "llm",
    "session-memory"
  ],
  "author": "DevForth (https://devforth.io)",
  "license": "ISC",
  "description": "AI agent plugin for AdminForth with tool-based workflows and persistent chat sessions",
  "devDependencies": {
    "@types/node": "latest",
    "semantic-release": "^24.2.1",
    "semantic-release-slack-bot": "^4.0.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.8",
    "@langchain/langgraph-checkpoint": "^1.0.1",
    "adminforth": "^2.52.0",
    "dayjs": "^1.11.20",
    "langchain": "^1.3.3",
    "multer": "^2.1.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "semantic-release-slack-bot",
        {
          "packageName": "@adminforth/agent",
          "notifyOnSuccess": true,
          "notifyOnFail": true,
          "slackIcon": ":package:",
          "markdownReleaseNotes": true
        }
      ]
    ]
  },
  "branches": [
    "main",
    {
      "name": "next",
      "prerelease": true
    }
  ]
}
